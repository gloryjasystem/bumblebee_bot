# ─── Telegram Bot ───────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OWNER_TELEGRAM_ID=123456789

# ─── База данных (Railway PostgreSQL) ───────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Шифрование токенов ─────────────────────────────────────
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=ваш_32_байтный_fernet_ключ_base64=

# ─── NOWPayments (крипто-оплата) ────────────────────────────
NOWPAYMENTS_API_KEY=ваш_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=ваш_nowpayments_ipn_secret

# ─── Публичный URL бота на Railway ──────────────────────────
# После деплоя — вставить реальный URL из Railway dashboard
SERVER_URL=https://your-app.railway.app
WEBAPP_URL=https://your-app.railway.app/webapp

# ─── Режим работы ───────────────────────────────────────────
# webhook — для продакшена на Railway
# polling  — для локальной разработки
BOT_MODE=polling
